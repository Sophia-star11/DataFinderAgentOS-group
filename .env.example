# ============================================================
# 智能瞭望与智能问数系统 - 环境配置文件
# ============================================================

# 系统名称配置
SYSTEM_NAME=智能瞭望与智能问数系统
SYSTEM_SHORT_NAME=DataFinderAgentOS

# 服务端口配置
PORT=10010

# 调试模式配置（生产环境请设置为 false）
DEBUG=true
AUTORELOAD=true

# 安全密钥配置（生产环境必须使用强随机密钥）
# 可通过命令生成: python -c "import secrets; print(secrets.token_hex(32))"
COOKIE_SECRET=datafinderagentos-token

# 数据库路径配置
DATABASE_PATH=./database/finderos.db

# 日志级别配置（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 默认管理员账户配置（首次启动时创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456

# 加密密钥配置（用于加密存储 API Key 等敏感信息）
# 必须设置，可通过命令生成: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=
